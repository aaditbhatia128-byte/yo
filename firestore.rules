// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - displayName: string (required, < 100 chars)
//   - username: string (required, < 50 chars)
//   - photoURL: string (optional, URL)
//   - publicKey: string (optional, < 2000 chars) - RSA SPKI
//   - lastSeen: timestamp (required)
//   - status: string (optional, < 100 chars)
//   - bio: string (optional, < 500 chars)
//   - theme: string (optional)
//   - avatarShape: string (optional)
//   - accentColor: string (optional)
//   - savedContacts: list (optional)
//
// Collection: conversations
// Document ID: {convId}
// Fields:
//   - id: string (optional)
//   - participants: list (required, size 2-50) - UIDs
//   - type: string (required, enum: ['direct', 'group'])
//   - updatedAt: timestamp (required)
//   - lastMessage: string (optional, < 1000 chars)
//   - isAI: bool (optional)
//   - groupName: string (optional, for type='group')
//   - groupDescription: string (optional)
//   - groupAvatar: string (optional)
//   - groupRules: string (optional)
//   - adminId: string (optional)
//   - inviteCode: string (optional)
//
// Collection: join_requests
// Document ID: {requestId}
// Fields:
//   - conversationId: string
//   - userId: string
//   - status: string (pending, accepted, rejected)
//   - createdAt: timestamp
//
// Collection: conversations/{convId}/messages
// Document ID: {msgId}
// Fields:
//   - conversationId: string (required)
//   - senderId: string (required)
//   - contentEncrypted: string (required)
//   - iv: string (required)
//   - encKeys: map (optional, for groups)
//   - type: string (required)
//   - attachmentUrl: string (optional, URL)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aaditbhatia128@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 &&
             (!('photoURL' in data) || isValidUrl(data.photoURL)) &&
             (!('publicKey' in data) || (data.publicKey is string)) &&
             (!('status' in data) || (data.status is string)) &&
             (!('bio' in data) || (data.bio is string));
    }

    function isValidConversation(data) {
      return data.participants is list && data.participants.size() >= 2 &&
             data.participants.hasAll([request.auth.uid]) &&
             data.type in ['direct', 'group'] &&
             data.updatedAt is timestamp &&
             (!('groupRules' in data) || (data.groupRules is string && data.groupRules.size() <= 6000)) &&
             (!('inviteCode' in data) || (data.inviteCode is string));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['conversationId', 'senderId', 'createdAt', 'contentEncrypted', 'iv', 'type']) &&
             data.conversationId is string &&
             (data.senderId == request.auth.uid || data.senderId == 'glacier-ai' || data.senderId == 'system') &&
             data.createdAt is timestamp;
    }

    function isValidJoinRequest(data) {
      return data.keys().hasAll(['conversationId', 'userId', 'status', 'createdAt']) &&
             data.conversationId is string &&
             data.userId == request.auth.uid &&
             data.status == 'pending' &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /conversations/{convId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        (resource.data.type == 'group' && resource.data.inviteCode != null)
      );
      allow create: if isAuthenticated() && isValidConversation(request.resource.data);
      allow update: if isAuthenticated() && (
                      (request.auth.uid in resource.data.participants && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'lastMessage', 'participants'])) ||
                      (resource.data.adminId == request.auth.uid && isValidConversation(request.resource.data))
                    );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.adminId == request.auth.uid);

      match /messages/{msgId} {
        allow read: if isAuthenticated() && 
                        request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated() && 
                        request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
                        isValidMessage(request.resource.data);
        allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.senderId);
      }
    }

    match /join_requests/{reqId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.adminId
      );
      allow create: if isAuthenticated() && isValidJoinRequest(request.resource.data);
      allow update: if isAuthenticated() && (
        request.auth.uid == get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.adminId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.adminId
      );
    }
  }
}
